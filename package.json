{
  "name": "vue3-vant-mobile",
  "type": "module",
  "version": "3.16.0",
  "packageManager": "pnpm@11.12.0",
  "description": "An mobile web apps template based on the Vue 3 ecosystem",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "dev": "cross-env MOCK_SERVER_PORT=8086 vite",
    "build:dev": "vue-tsc --noEmit && vite build --mode development",
    "build:pro": "vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp --commit --push --tag",
    "typecheck": "vue-tsc --noEmit",
    "commitlint": "commitlint --edit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@unhead/vue": "3.1.8",
    "@vant/touch-emulator": "^1.5.0",
    "@vant/use": "^1.6.0",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.1",
    "echarts": "^6.1.0",
    "lodash-es": "^4.18.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "resize-detector": "^0.3.0",
    "vant": "^4.10.0",
    "vconsole": "^3.15.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@iconify-json/carbon": "^1.2.24",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.1.1",
    "@types/nprogress": "^0.2.3",
    "@unocss/eslint-config": "66.7.5",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-legacy": "^8.2.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.2",
    "bumpp": "^11.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-format": "^2.0.1",
    "less": "^4.6.7",
    "lint-staged": "^17.0.8",
    "mockjs": "^1.1.0",
    "postcss-mobile-forever": "^5.0.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unocss": "66.7.5",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.4",
    "vite-plugin-mock-dev-server": "^2.4.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-sitemap": "^0.8.2",
    "vite-plugin-vconsole": "^2.1.1",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue-tsc": "^3.3.7"
  },
  "resolutions": {
    "vite": "^8.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint $1"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
